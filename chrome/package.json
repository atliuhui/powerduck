{
  "name": "powerduck-chrome",
  "version": "0.1.1",
  "private": true,
  "description": "PowerDuck packaged as a Chrome (MV3) extension that opens the H5 app in a new tab.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atliuhui/powerduck.git"
  },
  "bugs": {
    "url": "https://github.com/atliuhui/powerduck/issues"
  },
  "homepage": "https://github.com/atliuhui/powerduck#readme",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && vite build && node scripts/build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "@powerduck/shared": "*"
  }
}
